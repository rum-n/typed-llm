{
  "name": "typed-llm",
  "version": "0.1.0",
  "description": "Reliably typed LLM outputs — schema definition, coercion, parsing, retry, and streaming for any LLM provider",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsdown src/index.ts",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "llm",
    "schema",
    "typescript",
    "openai",
    "anthropic",
    "structured-output",
    "zod",
    "validation",
    "streaming"
  ],
  "author": "Rumen Manev",
  "license": "MIT",
  "devDependencies": {
    "tsdown": "^0.11.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "peerDependencies": {
    "zod": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "zod": {
      "optional": true
    }
  }
}
